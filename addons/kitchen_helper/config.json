{
  "name": "Küchenhelfer",
  "version": "1.0.0",
  "slug": "kitchen_helper",
  "description": "Rezept-Datenbank mit KI-Generierung, Kalenderplanung und Einkaufsliste für Home Assistant.",
  "url": "https://github.com/ChertiGER/hoas_kitchen_helper",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "services",
  "boot": "auto",
  "ingress": true,
  "ingress_port": 8000,
  "panel_icon": "mdi:silverware-fork-knife",
  "panel_title": "Küchenhelfer",
  "homeassistant_api": true,
  "options": {
    "llm_provider": "openai",
    "openai_api_key": "",
    "openai_model": "gpt-4o-mini",
    "custom_openai_url": "",
    "anthropic_api_key": "",
    "anthropic_model": "claude-3-5-haiku-latest",
    "use_ha_conversation": false,
    "ha_conversation_entity": "conversation.google_ai_conversation"
  },
  "schema": {
    "llm_provider": "list(openai|anthropic|openai_compatible)",
    "openai_api_key": "str?",
    "openai_model": "str?",
    "custom_openai_url": "str?",
    "anthropic_api_key": "str?",
    "anthropic_model": "str?",
    "use_ha_conversation": "bool?",
    "ha_conversation_entity": "str?"
  }
}
